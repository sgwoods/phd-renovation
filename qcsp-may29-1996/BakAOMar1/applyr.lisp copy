(defun load-applyr () (load 
 	     "Macintosh HD:Languages:Allegro Common Lisp:qcsp:applyr.lisp"))

(defvar *debug-app* t)

(defun applyR ( xi yj relation curMode maxDepth  curDepth )
" Returns tri logic value: one of true, fail, poss "

(if *debug-app*
    (comment3 "ApplyR call : xi, yj, depth" 
	  (DomVal-Name xi) (DomVal-Name yj) curDepth))

  (let* (
	 (return-val 'unset)
	 )

    (if (or (null xi) (null yj))
      
	;; return
	(setq return-val 'poss)

      (let* (
	     (Rlocal  (apply-relation xi yj relation))
	     )

	(if (fail3-p Rlocal)    ;; ie Rlocal = fail

	    ;; return
	    (setq return-val 'fail)

	  (cond

	   ( (eq curMode 'initial)
	     (setq return-val
		   (let* (  (dn (applyDown xi yj relation maxDepth curDepth))   )
		     (if (fail3-p dn)
			 'fail
		       (let ( (up (applyUp xi yj relation maxDepth curDepth))   )
			 (and3 (list dn up)) )))) )
     
	   ( (eq curMode 'down)
	     (setq return-val (applyDown xi yj relation maxDepth curDepth)) )

	   ( (eq curMode 'up)
	     (setq return-val (applyUp   xi yj relation maxDepth curDepth)) )

	   ( t  
	     (setq return-val 'error-in-curMode) )
	 )) ; cond, if
	)) ; if

    (if *debug-app*    (comment3 "applyR xi yj return-val" 
				 (DomVal-Name xi) (DomVal-Name yj)  return-val))
    return-val

    )) ;; defun

(defun apply-relation ( xa yb relation )
  (apply relation (list xa yb)))

(defun applyUp ( xi yj relation maxDepth curDepth )
" Returns tri logic value: one of true, fail, poss "

(if *debug-app*(comment3 "ApplyUp call : xi, yj, depth" 
			 (DomVal-Name xi) (DomVal-Name yj) curDepth))

  (let* (
	 (newDepth (1+ curDepth))
	 (return-val 'unset)
	 )
    (if (> newDepth maxDepth)
	
	;; return
	(setq return-val 'true)

      (if (or (leaf-p xi) (leaf-p yj))
	
	  ;; return
	  (setq return-val 'poss)

	(let* (
	       (xlp    (DomVal-LeftParent  xi))
	       (xrp    (DomVal-RightParent xi))
	       (ylp    (DomVal-LeftParent  yj))
	       (yrp    (DomVal-RightParent yj))

	       (RLL (applyR xlp ylp relation 'up maxDepth newDepth))
	       (RLR (applyR xlp yrp relation 'up maxDepth newDepth))
	       (RRL (applyR xrp ylp relation 'up maxDepth newDepth))
	       (RRR (applyR xrp yrp relation 'up maxDepth newDepth))
      
	       (RL (or3 (list RLL RLR)))
	       (RR (or3 (list RRL RRR)))
	       )

	  (if (fail3-p RL)
	      (markit   xi xlp 'lp))

	  (if (fail3-p RR)
	      (markit   xi xrp 'rp))

	  (setq return-val (or3 (list RL RR)))
	  )) ; if
	) ; if

    (if *debug-app*    (comment3 "applyUp xi yj return-val" 
				 (DomVal-Name xi) (DomVal-Name yj) return-val))
    return-val

    )) ; defun
    

(defun applyDown ( xi yj relation maxDepth curDepth )
" ApplyDown returns a tri logic value one of true fail poss "

(if *debug-app* (comment3 "ApplyDown call : xi, yj, depth" 
			  (DomVal-Name xi) (DomVal-Name yj) curDepth))

  (let* (
	 (newDepth (1+ curDepth))
	 (return-val   'unset)
	 )
    (if (> newDepth maxDepth)

	;; return
	(setq return-val 'true)

      (if (or (leaf-p xi) (leaf-p yj))
	
	  ;; return
	  (setq return-val 'poss)

	(let* (
	       (xlc    (DomVal-LeftChild  xi))
	       (xlc-type (DomVal-LeftChildType xi))  
	       (xrc    (DomVal-RightChild xi))
;;	       (xrc-type (DomVal-RightChildType xi))
	       (ylc    (DomVal-LeftChild  yj))
	       (ylc-type (DomVal-LeftChildType yj))
	       (yrc    (DomVal-RightChild yj))
;;	       (yrc-type (DomVal-RightChildType yj))

	       (RLL (applyR xlc ylc relation 'down maxDepth newDepth))
	       (RLR (applyR xlc yrc relation 'down maxDepth newDepth))
	       (RRL (applyR xrc ylc relation 'down maxDepth newDepth))
	       (RRR (applyR xrc yrc relation 'down maxDepth newDepth))
    	       )

	  ;;
	  ;; note downlinks are paired and/and or or/or never split a/o or o/a
	  ;;

	  (cond

	   ;; **************************************************
	   ;; OR/OR case
	   ;;
	   ( (and (eq xlc-type 'or) (eq ylc-type 'or))   
	     (let* (
		    (RL (or3 (list RLL RLR)))
		    (RR (or3 (list RRL RRR)))
		    )
	       
	       (if (fail3-p RL)
		   (markit   xi xlc 'lc))

	       (if (fail3-p RR)
		   (markit   xi xrc 'rc))

	       ;; return
	       (setq return-val (or3 (list RL RR))) )) 

	   ;; **************************************************
	   ;; AND/AND case
	   ;;
	   ( (and (eq xlc-type 'or) (eq ylc-type 'or))
	     (let* (
		    (RDOWN (and3 RLL RLR RRL RRR))
		    )

	       (if (fail3-p RDOWN)
		   (progn
		     (markit   xi xlc 'lc)
		     (markit   xi xrc 'rc)))

	       ;; return
	       (setq return-val RDOWN) ))

	   ;; **************************************************
	   ;; OR/AND case
	   ;;
	   ( (and (eq xlc-type 'or) (eq ylc-type 'and))
	     (let* (
		    (RL (and3 RLL RLR))
		    (RR (and3 RRL RRR))
		    )
	       (if (fail3-p RL)
		   (markit   xi xlc'lc))

	       (if (fail3-p RR)
		   (markit   xi xrc 'rc))

	       ;; return
	       (setq return-val (or3 (list RL RR))) ))

	   ;; **************************************************
	   ;; AND/OR case
	   ;;
	   ( (and (eq xlc-type 'and) (eq ylc-type 'or))
	     (let* (
		    (RL (and3 RLL RRL))
		    (RR (and3 RLR RRR))
		    )
	       (if (and (fail3-p RL) (fail3-p RR))
		   (progn
		     (markit   xi xlc 'lc)
		     (markit   xi xrc 'rc)
		     
		     ;; return
		     (setq return-val 'fail))
		 
		 ;; return
		 (setq return-val 'true)) ))

	   ( t
		 ;; return ERROR
		 (setq return-val 'error-in-graph-from-cond))

	   ) ; cond

	  (if *debug-app* (comment3 "applyDown xi yj return-val" 
				    (DomVal-Name xi) (DomVal-Name yj) return-val))
	  return-val  ;; applyDown return value

	  )) ; if
      ) ; if
    )) ; defun


(defun or3 ( orvals )
" return tri logic value (pessimistic) OR  of a list of tri logic values "
  (if (null orvals)
      'fail
    (if (atom (car orvals))
	(if (member 'true orvals) 
	    'true
	  (if (member 'poss orvals) 
	      'poss
	    'fail))
    (let* (
	   (thisform  (first orvals))
	   (restforms (rest  orvals))
	   (thisval   (apply (car thisform) (cdr thisform)))
	   (sofar thisval)
	   )

      (loop

       (if (or (null restforms) (eq sofar 'true)) (return))
       
       (setq thisform  (car restforms))
       (setq restforms (cdr restforms))   
       (setq thisval (apply (car thisform) (cdr thisform)))

       (if (eq thisval 'true)
	   (setq sofar 'true)
	 (if (eq thisval 'poss)
	     (setq sofar 'poss) 
	   (if (not (eq thisval 'fail))
	       (progn
		 (if *debug-app*  (comment3 "Error in or3: thisform thisval nil"
					    thisform thisval nil))
		 (setq sofar 'fail)
		 ))))
       )

      ;; return result
      sofar
      ))))

(defun and3 ( andvals )
" return tri logic value (pessimistic) AND  of a list of tri logic values "
  (if (null andvals)
      'fail
    (if (atom (car andvals))
	(if (member 'fail andvals) 
	    'fail 
	  (if (member 'poss andvals) 
	      'poss
	    'true))

    (let* (
	   (thisform  (first andvals))
	   (restforms (rest  andvals))
	   (thisval   (apply (car thisform) (cdr thisform)))
	   (sofar thisval)
	   )

      (loop

       (if (or (null restforms) (eq sofar 'fail)) (return))
       
       (setq thisform  (car restforms))
       (setq restforms (cdr restforms))   
       (setq thisval (apply (car thisform) (cdr thisform)))

       (if (eq thisval 'fail)
	   (setq sofar 'fail)
	 (if (eq thisval 'poss)
	     (setq sofar 'poss) 
	   (if (not (eq thisval 'true))
	       (progn
		 (if *debug-app* (comment3 "Error in and3: thisform thisval nil"
					   thisform thisval nil))
		 (setq sofar 'fail)
		 ))))
       )

      ;; return result
      sofar
      ))))

(defun not3 ( notval )
" return tri logic value of not "
  (if (eq notval 'true)
      'fail
    (if (eq notval 'poss)
	'fail
      'true)))

(defun poss3-p ( val )
" return binary logic t iff val is poss "
 (eq val 'poss))

(defun fail3-p ( val )
" return binary logic t iff val is fail "
 (eq val 'fail))

(defun true3-p ( val )
" return binary logic t iff val is true "
 (eq val 'true))


	  
