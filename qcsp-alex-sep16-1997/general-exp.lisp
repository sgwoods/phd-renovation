(defun add-result-to-file-for-exp-other-than-static-ordering ( output-stream component-file )
  "
make a list of results we are interested in and append it to a file.
Those results are:
(0 plan-name)
(1 number-of-components-of-the-plan)
(2 number-of-constraints-of-the-plan)
(3 program-name)
(4 number-of-components-of-the-program)
(5 number-of-this-plan-related-components)
(6 ratio-of-5-over-4)
(7 average-domain-size)
;;(8 max-domain-size)
;;(9 min-domain-size)
(10 constaint-checks)
(11 successful-constraint-checks)
(12 failed-constraint-checks) 
(13 ratio-of-11-over-10)
(14 length-of-solution-set)
(15 cpu-search-time)
(16 *constraint-possible-data-dependency-cks*)
(17 *constraint-guaranteed-data-dependency-cks*)
(18 *constraint-same-data-dependency-cks*)
(19 *constraint-control-data-dependency-cks*)
(20 *constraint-same-variable-cks*)
(21 ratio of 15 over 10)
"
(let* ((r0 (nth 0 *current-template*))
       (r1 (length (nth 1 *current-template*)))
       (r2 (length (nth 2 *current-template*)))
       (r3 component-file)
       (r4 (length *current-situation*))
       (r5 (get-number-of-cur-plan-related-components))
       (r6 (coerce (/ r5 r4) 'float))
       (r7 *RECALL-avg-var-len*)
       (r10 *constraint-cks*)
       (r11 *constraint-success*)
       (r12 *constraint-failure*)
       (r13 (coerce (/ r11 r10) 'float))
       (r14 (length *solution-set*))
       (r15 *RECALL-search-time*)
;;following are added on December 26, 1996
       (r16 *constraint-possible-data-dependency-cks*)
       (r17 *constraint-guaranteed-data-dependency-cks*)
       (r18 *constraint-same-data-dependency-cks*)
       (r19 *constraint-control-data-dependency-cks*)
       (r20 *constraint-same-variable-cks*)
       (r21 (coerce (/ r15 r10) 'float))
       
       (r22 *node-consistency-checks*) 
       (r23 *node-type-consistency-checks*) 
       (r24 *node-type-consistency-ck-ok*) 
       (r25 *node-type-consistency-ck-fail*) 

       (r26 *dyn-rearr-cost*)
       (r27 *dfa-rearr-cost*)
       )
(format output-stream  "~a~%"
	(list r0 r1 r2 r3 r4 r5 r6 r7 r10 r11 r12 r13 r14 r15 r16 r17 r18 r19 r20 r21 r22 r23 r24 r25 r26 r27))))




(defun get-number-of-cur-plan-related-components ()
  (let ((affected-count 0)
	(type-list (mapcar #'first 
			   (get-type-set 
			    (mapcar #'caadr (nth 1 *current-template*))))))
    
    (setq *template-hash* (make-hash-table))
    (dolist (element type-list)
	    (setf (gethash element *template-hash*) 0))
    (dolist (element *current-situation*)
	    (let* ((this-node (second element))
		   (temp (gethash this-node *template-hash*)))
	      (if (not (null temp))  
		  (setf (gethash this-node *template-hash*) (+ temp 1)))))
    (dolist (element type-list)
	    (let ((tmp-cnt (gethash element *template-hash*)))
	      (if (not (null tmp-cnt))
		  (setq affected-count 
			(+  tmp-cnt affected-count)))))
  affected-count))
;;*************************************************************************************
;;
;;result is a list
(defun pick-two-for-xvgr (template-posi item-1 item-2 input-file output-file)

  (setq *my-result-xvgr*  (open output-file
				  :direction :output
				  :if-exists :overwrite
				  :if-does-not-exist :create))

  (with-open-file (in-stream input-file
			     :direction :input)
		  (let ((exp (read in-stream nil *end-of-file* nil)))
		    (dolist (t-elem exp)
			    (let* ((this-templ (nth template-posi t-elem))
				   (item1 (nth item-1 this-templ))
				   (item2 (nth item-2 this-templ)))
			     (format *my-result-xvgr* "~a ~a~%" item1 item2)))))
  
  (close *my-result-xvgr*)
)

;; three: cons-cks + type-consis-cks
(defun pick-three-for-xvgr (template-posi item-1 item-2 item-3 input-file output-file)

  (setq *my-result-xvgr*  (open output-file
				  :direction :output
				  :if-exists :overwrite
				  :if-does-not-exist :create))

  (with-open-file (in-stream input-file
			     :direction :input)
		  (let ((exp (read in-stream nil *end-of-file* nil)))
		    (dolist (t-elem exp)
			    (let* ((this-templ (nth template-posi t-elem))
				   (item1 (nth item-1 this-templ))
				   (item2 (nth item-2 this-templ))
				   (item3 (nth item-3 this-temp1)))
			     (format *my-result-xvgr* "~a ~a~%" item1 (+ item2 item3))))))
  
  (close *my-result-xvgr*)
)
