;;
;; General experiment program, input is the (data-file-list, template-list, print-template-option)
;; the template-list is just a list of template names that can be found in the global variable
;; *template-object-list*
;;
(defun experiment ( data-file-list template-list output-file &optional (print-template nil))
  (setq *my-result-stream*  (open output-file
				  :direction :output
				  :if-exists :overwrite
				  :if-does-not-exist :create))
  (format *my-result-stream* "~a~%" "(")
  (dolist (files-element data-file-list)
	  (progn
	    (format *my-result-stream* " ~a~%" "(")
;;	    (load "new-setup.fasl")
	    (format t
		    "~%Do files: ~a!"
		    files-element) 
	    (test-main (nth 0 files-element)
		       (nth 1 files-element)
		       (nth 2 files-element))
	    (dolist (template template-list)
		    (progn
		      (adt :template-id template
			   :forward-checking t
			   :dynamic-rearrangement t
			   :debug nil  
			   :debug-csp nil) 
;;			   :output-file "test-output-file")
		      (add-result-to-file-for-exp-other-than-static-ordering *my-result-stream* 
									     (nth 0 files-element))
		      
		      (if print-template 
			  (format t "~%Template ~a," 
				  (get-templ-object template))
			(format t "~%Template ~a," 
				(first (get-templ-object template))))	
		      (format t "~%Result length is ~a!~%"
			      (length *solution-set*))))
	    (format *my-result-stream* "~% ~a~%" ")")))
  (format *my-result-stream* "~%~a~%" ")")
  (close *my-result-stream*)
  )


