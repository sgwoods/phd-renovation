# AC3 + BT constraint checks, ij4 data showing confidence interval

set xlabel "Program statements"
set xrange [0:1049]
set xtics 0,50
set ylabel "Constraint checks"
set yrange [0:600000]
set ytics 0,50000

set key 
set term postscript landscape monochrome "Times-Roman" 14
set output "ij4-acfcdr-cc-ci.ps"
plot "ij4-plot-cc.ci" title "AC3+FCDR" with lines, "ij4-plot-cc.ci" title "AC3+FCDR 95% CI" with errorbars



