# Compariing ij1, ij4 based on seconds, no confidence interval shown

set xlabel "Program statements"
set xrange [0:1049]
set xtics 0,50
set ylabel "CPU seconds"
set yrange [0:600]
set ytics 0,30
set key 300,540
set term postscript landscape monochrome "Times-Roman" 14
set output "compare-1-4-sec.ps"
plot "ij1-plot-sec.ci" title "BT" with linespoints 4 12, "ij4-plot-sec.ci" title "AC3 + FCDR" with linespoints 4 5



