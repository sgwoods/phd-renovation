# BT seconds, ij1 data showning confidence interval

set xlabel "Program statements"
set xrange [0:1049]
set xtics 0,50
set ylabel "CPU seconds"
set yrange [0:600]
set ytics 0,30
set key 300,540
set term postscript landscape monochrome "Times-Roman" 14
set output "ij1-bt-sec-ci.ps"
plot "ij1-plot-sec.ci" title "BT" with lines, "ij1-plot-sec.ci" title "BT 95% CI" with errorbars



