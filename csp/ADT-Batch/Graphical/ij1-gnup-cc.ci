# BT constraint checks, ij1 data showning confidence interval

set xlabel "Program statements"
set xrange [0:1049]
set xtics 0,50
set ylabel "Constraint checks"
set yrange [0:600000]
set ytics 0,50000

set key 
set term postscript landscape monochrome "Times-Roman" 14
set output "ij1-bt-cc-ci.ps"
plot "ij1-plot-cc.ci" title "BT" with lines, "ij1-plot-cc.ci" title "BT 95% CI" with errorbars



