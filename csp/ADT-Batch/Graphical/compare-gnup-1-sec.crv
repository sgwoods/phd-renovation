# Curve fit : see least-squares-maple information in IJCAI directory for Phd Thesis

set xlabel "Program statements"
set xrange [0:1049]
set xtics 0,50
set ylabel "CPU seconds"
set yrange [0:600]
set ytics 0,30
set key 300,540
set term postscript landscape monochrome "Times-Roman" 14
set output "compare-1-crv.ps"
plot "ij1-plot-sec.ci" title "BT" with linespoints 1 7, ((0.001394572234 * x * x)  + (0.1881438930 *  x) - 20.06538465) title "Quadratic fn" with lines 5









