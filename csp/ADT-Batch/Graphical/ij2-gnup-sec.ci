# FCDR seconds, ij2 data showing confidence interval

set xlabel "Program statements"
set xrange [0:1049]
set xtics 0,50
set ylabel "CPU seconds"
set yrange [0:600]
set ytics 0,30

set key 
set term postscript landscape monochrome "Times-Roman" 14
set output "ij2-fcdr-sec-ci.ps"
plot "ij2-plot-sec.ci" title "FCDR" with lines, "ij2-plot-sec.ci" title "FCDR 95% CI" with errorbars



